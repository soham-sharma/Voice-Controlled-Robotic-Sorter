            <diffuse>0.80 0.45 0.10 1</diffuse>
            <specular>0.30 0.20 0.10 1</specular>
          </material>
        </visual>
        <visual name="right_wall_visual">
          <pose>0.085 0 0.05 0 0 0</pose>

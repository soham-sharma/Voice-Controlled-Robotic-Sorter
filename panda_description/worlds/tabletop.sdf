        </collision>

        <visual name="base_visual">
          <pose>0 0 0.005 0 0 0</pose>
          <geometry>
            <box>
              <size>0.18 0.18 0.01</size>
            </box>
          </geometry>
          <material>
            <ambient>0.80 0.45 0.10 1</ambient>
            <diffuse>0.80 0.45 0.10 1</diffuse>
            <specular>0.30 0.20 0.10 1</specular>
          </material>
        </visual>
        <visual name="front_wall_visual">
          <pose>0 0.085 0.05 0 0 0</pose>
          <geometry>
            <box>
              <size>0.18 0.01 0.10</size>
            </box>
          </geometry>
          <material>
            <ambient>0.80 0.45 0.10 1</ambient>
            <diffuse>0.80 0.45 0.10 1</diffuse>
            <specular>0.30 0.20 0.10 1</specular>
          </material>
        </visual>
        <visual name="back_wall_visual">
          <pose>0 -0.085 0.05 0 0 0</pose>
          <geometry>
            <box>
              <size>0.18 0.01 0.10</size>
            </box>
          </geometry>
          <material>
            <ambient>0.80 0.45 0.10 1</ambient>
